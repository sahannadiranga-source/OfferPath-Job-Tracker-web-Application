@page "/jobs/edit/{Id:int}"
@using System.Net.Http.Json
@using OfferPath.Client.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="form-card">
    <div class="form-title">Edit Job</div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert-box">@message</div>
    }

    @if (job == null)
    {
        <p>Loading job details...</p>
    }
    else
    {
        <div class="form-group">
            <label>Company</label>
            <input class="form-control" @bind="job.Company" />
        </div>

        <div class="form-group">
            <label>Position</label>
            <input class="form-control" @bind="job.Position" />
        </div>

        <div class="form-group">
            <label>Location</label>
            <input class="form-control" @bind="job.Location" />
        </div>

        <div class="form-group">
            <label>Status</label>
            <select class="form-control" @bind="job.Status">
                <option value="Applied">Applied</option>
                <option value="Interview">Interview</option>
                <option value="Rejected">Rejected</option>
                <option value="Offer">Offer</option>
            </select>
        </div>

        <div class="form-group">
            <label>Applied Date</label>
            <input type="date" class="form-control" @bind="job.AppliedDate" />
        </div>

        <div class="form-group">
            <label>Notes</label>
            <textarea class="form-control" @bind="job.Notes"></textarea>
        </div>

        <button class="btn-primary-custom" @onclick="UpdateJob">Update Job</button>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private JobApplicationModel? job;
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        job = await Http.GetFromJsonAsync<JobApplicationModel>($"api/Jobs/{Id}");
    }

    private async Task UpdateJob()
    {
        if (job == null)
            return;

        var response = await Http.PutAsJsonAsync($"api/Jobs/{Id}", job);

        if (response.IsSuccessStatusCode)
        {
            message = "Job updated successfully.";
            await Task.Delay(700);
            Navigation.NavigateTo("/jobs");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            message = "Failed to update job: " + error;
        }
    }
}