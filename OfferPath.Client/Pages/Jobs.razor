@page "/jobs"
@using System.Net.Http.Json
@using OfferPath.Client.Models
@using OfferPath.Client.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject UserSessionService Session

<div class="page-header">
    <div>
        <h3>Available Jobs</h3>
        <p class="muted-text">Discover career opportunities from recruiters.</p>
    </div>

    @if (Session.IsRecruiter)
    {
        <button class="btn-primary-custom" @onclick="GoToAddJob">
            + Post Job
        </button>
    }
</div>

<div class="table-toolbar">
    <div class="search-box">
        <input class="search-input"
               placeholder="Search company or position..."
               @bind="searchTerm"
               @bind:event="oninput" />
    </div>

    <div class="filter-box">
        <select class="filter-select" @bind="selectedJobType">
            <option value="">All Job Types</option>
            <option value="Full-time">Full-time</option>
            <option value="Part-time">Part-time</option>
            <option value="Internship">Internship</option>
            <option value="Contract">Contract</option>
            <option value="Remote">Remote</option>
        </select>
    </div>

    <div class="filter-box">
        <select class="filter-select" @bind="selectedCategory">
            <option value="">All Categories</option>
            @foreach (var category in Categories)
            {
                <option value="@category">@category</option>
            }
        </select>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert-box">@errorMessage</div>
}

<div class="table-card">
    @if (jobs == null)
    {
        <div class="empty-state">
            <p>Loading jobs...</p>
        </div>
    }
    else if (FilteredJobs.Count == 0)
    {
        <div class="empty-state">
            <h4>No jobs found</h4>
            <p>Try another search or filter.</p>
        </div>
    }
    else
    {
        <table class="jobs-table">
            <thead>
                <tr>
                    <th>Company</th>
                    <th>Role</th>
                    <th>Location</th>
                    <th>Type</th>
                    <th>Category</th>
                    <th>Salary</th>
                    <th>Deadline</th>
                    <th>Views</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in FilteredJobs)
                {
                    <tr>
                        <td>
                            <div class="table-primary-text">@item.Company</div>
                        </td>
                        <td>
                            <div class="table-primary-text">@item.Position</div>
                        </td>
                        <td>@item.Location</td>
                        <td>@item.JobType</td>
                        <td>@item.Category</td>
                        <td>@item.Salary</td>
                        <td>
                            <div class="deadline-cell">
                                <div>@item.Deadline.ToString("yyyy-MM-dd")</div>
                                <span class="@GetDeadlineBadgeClass(item.Deadline)">
                                    @GetDeadlineText(item.Deadline)
                                </span>
                            </div>
                        </td>
                        <td>@item.ViewCount</td>
                        <td>
                            <div class="action-buttons">
                                @if (Session.IsRecruiter)
                                {
                                    <button class="icon-btn edit-btn" @onclick="() => EditJob(item.Id)">
                                        Edit
                                    </button>
                                    <button class="icon-btn delete-btn" @onclick="() => DeleteJob(item.Id)">
                                        Delete
                                    </button>
                                }
                                else
                                {
                                    <button class="icon-btn view-btn" @onclick="() => ViewJob(item.Id)">
                                        View
                                    </button>
                                    <button class="icon-btn apply-btn" @onclick="() => ApplyNow(item.Id)">
                                        Apply Now
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<JobApplicationModel>? jobs;
    private string errorMessage = "";
    private string searchTerm = "";
    private string selectedJobType = "";
    private string selectedCategory = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadJobs();
    }

    private async Task LoadJobs()
    {
        try
        {
            jobs = await Http.GetFromJsonAsync<List<JobApplicationModel>>("api/Jobs");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
    private string GetDeadlineText(DateTime deadline)
    {
        var daysLeft = (deadline.Date - DateTime.Today).Days;

        if (daysLeft < 0)
            return "Expired";

        if (daysLeft == 0)
            return "Ends Today";

        if (daysLeft == 1)
            return "1 Day Left";

        if (daysLeft <= 7)
            return $"{daysLeft} Days Left";

        return "Open";
    }

    private string GetDeadlineBadgeClass(DateTime deadline)
    {
        var daysLeft = (deadline.Date - DateTime.Today).Days;

        if (daysLeft < 0)
            return "deadline-badge expired";

        if (daysLeft <= 1)
            return "deadline-badge urgent";

        if (daysLeft <= 7)
            return "deadline-badge warning";

        return "deadline-badge safe";
    }
    private List<string> Categories =>
        jobs?
            .Where(j => !string.IsNullOrWhiteSpace(j.Category))
            .Select(j => j.Category!.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(c => c)
            .ToList()
        ?? new List<string>();

    private List<JobApplicationModel> FilteredJobs =>
        jobs?
            .Where(j =>
                (string.IsNullOrWhiteSpace(searchTerm) ||
                 (!string.IsNullOrWhiteSpace(j.Company) &&
                  j.Company.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                 (!string.IsNullOrWhiteSpace(j.Position) &&
                  j.Position.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
                &&
                (string.IsNullOrWhiteSpace(selectedJobType) ||
                 string.Equals(j.JobType?.Trim(), selectedJobType.Trim(), StringComparison.OrdinalIgnoreCase))
                &&
                (string.IsNullOrWhiteSpace(selectedCategory) ||
                 string.Equals(j.Category?.Trim(), selectedCategory.Trim(), StringComparison.OrdinalIgnoreCase)))
            .ToList()
        ?? new List<JobApplicationModel>();

    private void GoToAddJob()
    {
        Navigation.NavigateTo("/jobs/add");
    }

    private void EditJob(int id)
    {
        Navigation.NavigateTo($"/jobs/edit/{id}");
    }

    private void ViewJob(int id)
    {
        Navigation.NavigateTo($"/jobs/details/{id}");
    }

    private void ApplyNow(int id)
    {
        if (!Session.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        Navigation.NavigateTo($"/jobs/details/{id}");
    }

    private async Task DeleteJob(int id)
    {
        var response = await Http.DeleteAsync($"api/Jobs/{id}");

        if (response.IsSuccessStatusCode)
        {
            await LoadJobs();
        }
        else
        {
            errorMessage = "Failed to delete job.";
        }
    }
}