@page "/register"

<h3>Register</h3>

<div class="mb-3">
    <label>Name</label>
    <input class="form-control" />
</div>

<div class="mb-3">
    <label>Email</label>
    <input class="form-control" />
</div>

<div class="mb-3">
    <label>Password</label>
    <input type="password" class="form-control" />
</div>

<div class="mb-3">
    <label>Confirm Password</label>
    <input type="password" class="form-control" />
</div>

<button class="btn btn-success">Register</button>