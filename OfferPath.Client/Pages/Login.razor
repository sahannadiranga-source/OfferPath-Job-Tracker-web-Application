@page "/login"
@using System.Net.Http.Json
@using OfferPath.Client.Models
@using OfferPath.Client.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject UserSessionService Session

<div class="auth-page">
    <div class="auth-card">
        <h2 class="form-title">Sign in</h2>
        <p class="muted-text">Access your account and continue.</p>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert-box">@message</div>
        }

        <div class="form-group">
            <label>Email</label>
            <input class="form-control" @bind="loginModel.Email" />
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" class="form-control" @bind="loginModel.Password" />
        </div>

        <button class="btn-primary-custom auth-submit" @onclick="LoginUser">Login</button>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string message = "";

    private async Task LoginUser()
    {
        var response = await Http.PostAsJsonAsync("api/Auth/login", loginModel);

        if (response.IsSuccessStatusCode)
        {
            var user = await response.Content.ReadFromJsonAsync<UserResponseModel>();

            if (user != null)
            {
                Session.CurrentUser = user;

                await Task.Delay(300);

                if (user.Role == "Recruiter")
                {
                    Navigation.NavigateTo("/dashboard");
                }
                else
                {
                    Navigation.NavigateTo("/jobs");
                }
            }
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            message = "Login failed: " + error;
        }
    }
}