@page "/jobs/add"
@using System.Net.Http.Json
@using OfferPath.Client.Models
@using OfferPath.Client.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject UserSessionService Session

@if (!Session.IsRecruiter)
{
    <div class="alert-box">Only recruiters can add jobs.</div>
}
else
{
    <div class="form-card">
        <div class="form-title">Create Job Post</div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert-box">@message</div>
        }

        <div class="form-group">
            <label>Company</label>
            <input class="form-control" @bind="job.Company" />
        </div>

        <div class="form-group">
            <label>Position</label>
            <input class="form-control" @bind="job.Position" />
        </div>

        <div class="form-group">
            <label>Location</label>
            <input class="form-control" @bind="job.Location" />
        </div>

        <div class="form-group">
            <label>Job Type</label>
            <select class="form-control" @bind="job.JobType">
                <option value="">Select Job Type</option>
                <option>Full-time</option>
                <option>Part-time</option>
                <option>Internship</option>
                <option>Contract</option>
                <option>Remote</option>
            </select>
        </div>

        <div class="form-group">
            <label>Salary</label>
            <input class="form-control" @bind="job.Salary" />
        </div>

        <div class="form-group">
            <label>Category</label>
            <input class="form-control" @bind="job.Category" />
        </div>

        <div class="form-group">
            <label>Experience Level</label>
            <select class="form-control" @bind="job.ExperienceLevel">
                <option value="">Select Level</option>
                <option>Entry Level</option>
                <option>Junior</option>
                <option>Mid Level</option>
                <option>Senior</option>
            </select>
        </div>

        <div class="form-group">
            <label>Posted Date</label>
            <input type="date" class="form-control" @bind="job.PostedDate" />
        </div>

        <div class="form-group">
            <label>Deadline</label>
            <input type="date" class="form-control" @bind="job.Deadline" />
        </div>

        <div class="form-group">
            <label>Job Image URL</label>
            <input class="form-control" @bind="job.ImageUrl" />
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea class="form-control" rows="5" @bind="job.Description"></textarea>
        </div>

        <button class="btn-primary-custom" @onclick="SaveJob">Publish Job</button>
    </div>
}

@code {
    private JobApplicationModel job = new()
    {
        PostedDate = DateTime.Today,
        Deadline = DateTime.Today.AddDays(30)
    };

    private string message = "";

    private async Task SaveJob()
    {
        var response = await Http.PostAsJsonAsync("api/Jobs", job);

        if (response.IsSuccessStatusCode)
        {
            message = "Job published successfully.";
            await Task.Delay(700);
            Navigation.NavigateTo("/jobs");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            message = "Failed to publish job: " + error;
        }
    }
}