@page "/jobs/add"
@using System.Net.Http.Json
@using OfferPath.Client.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="form-card">
    <div class="form-title">Add New Job</div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert-box">@message</div>
    }

    <div class="form-group">
        <label>Company</label>
        <input class="form-control" @bind="job.Company" />
    </div>

    <div class="form-group">
        <label>Position</label>
        <input class="form-control" @bind="job.Position" />
    </div>

    <div class="form-group">
        <label>Location</label>
        <input class="form-control" @bind="job.Location" />
    </div>

    <div class="form-group">
        <label>Status</label>
        <select class="form-control" @bind="job.Status">
            <option value="">Select Status</option>
            <option value="Applied">Applied</option>
            <option value="Interview">Interview</option>
            <option value="Rejected">Rejected</option>
            <option value="Offer">Offer</option>
        </select>
    </div>

    <div class="form-group">
        <label>Applied Date</label>
        <input type="date" class="form-control" @bind="job.AppliedDate" />
    </div>

    <div class="form-group">
        <label>Notes</label>
        <textarea class="form-control" @bind="job.Notes"></textarea>
    </div>

    <button class="btn-primary-custom" @onclick="SaveJob">Save Job</button>
</div>

@code {
    private JobApplicationModel job = new()
    {
        AppliedDate = DateTime.Today
    };

    private string message = "";

    private async Task SaveJob()
    {
        var response = await Http.PostAsJsonAsync("api/Jobs", job);

        if (response.IsSuccessStatusCode)
        {
            message = "Job saved successfully.";
            await Task.Delay(700);
            Navigation.NavigateTo("/jobs");
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            message = "Failed to save job: " + error;
        }
    }
}