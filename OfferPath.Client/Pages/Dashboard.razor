@page "/dashboard"
@using System.Net.Http.Json
@using OfferPath.Client.Models
@inject HttpClient Http

<div class="page-header">
    <h3>Dashboard Overview</h3>
</div>

<div class="dashboard-grid">
    <div class="stat-card">
        <h4>Total Jobs</h4>
        <p>@totalJobs</p>
    </div>

    <div class="stat-card">
        <h4>Applied</h4>
        <p>@appliedCount</p>
    </div>

    <div class="stat-card">
        <h4>Interview</h4>
        <p>@interviewCount</p>
    </div>

    <div class="stat-card">
        <h4>Offers</h4>
        <p>@offerCount</p>
    </div>
</div>

@code {
    private List<JobApplicationModel> jobs = new();
    private int totalJobs;
    private int appliedCount;
    private int interviewCount;
    private int offerCount;

    protected override async Task OnInitializedAsync()
    {
        var result = await Http.GetFromJsonAsync<List<JobApplicationModel>>("api/Jobs");

        if (result != null)
        {
            jobs = result;
            totalJobs = jobs.Count;
            appliedCount = jobs.Count(x => x.Status == "Applied");
            interviewCount = jobs.Count(x => x.Status == "Interview");
            offerCount = jobs.Count(x => x.Status == "Offer");
        }
    }
}