@page "/"
@using System.Net.Http.Json
@using OfferPath.Client.Models
@using OfferPath.Client.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject UserSessionService Session

<div class="home-page">
    <section class="hero-card">
        <div class="hero-content">
            <div class="hero-text">
                <span class="hero-badge">Smart Job Tracking Platform</span>
                <h1>Track every opportunity with confidence</h1>
                <p>
                    OfferPath helps job seekers discover opportunities and helps recruiters
                    publish openings with a clean, modern experience. Stay organized,
                    monitor progress, and keep your hiring journey clear and structured.
                </p>

                <div class="hero-actions">
                    <a href="/jobs" class="btn-light-custom">View Jobs</a>

                    @if (Session.IsRecruiter)
                    {
                        <a href="/jobs/add" class="btn-outline-light-custom">Post a Job</a>
                    }
                    else
                    {
                        <a href="/register" class="btn-outline-light-custom">Get Started</a>
                    }
                </div>
            </div>

            <div class="hero-stats">
                <div class="mini-stat-card">
                    <h3>@totalJobs</h3>
                    <p>Open Opportunities</p>
                </div>
                <div class="mini-stat-card">
                    <h3>@totalCompanies</h3>
                    <p>Companies Hiring</p>
                </div>
                <div class="mini-stat-card">
                    <h3>@internshipCount</h3>
                    <p>Internships</p>
                </div>
            </div>
        </div>
    </section>

    <section class="home-info-grid">
        <div class="info-card">
            <h3>For Job Seekers</h3>
            <p>
                Browse jobs by company, role, location, and category.
                Stay updated with fresh opportunities and never miss a deadline.
            </p>
        </div>

        <div class="info-card">
            <h3>For Recruiters</h3>
            <p>
                Publish job openings, manage listings, track views,
                and keep hiring organized through one simple dashboard.
            </p>
        </div>

        <div class="info-card">
            <h3>Fast & Clear</h3>
            <p>
                A clean interface, structured listings, and quick navigation
                make job searching and posting easier for everyone.
            </p>
        </div>
    </section>

    <section class="recent-jobs-section">
        <div class="section-header">
            <div>
                <h2>Recent Jobs</h2>
                <p class="muted-text">Fresh opportunities added recently.</p>
            </div>
            <button class="btn-primary-custom" @onclick="GoToJobs">Browse All Jobs</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert-box">@errorMessage</div>
        }
        else if (recentJobs == null)
        {
            <div class="empty-state">
                <p>Loading jobs...</p>
            </div>
        }
        else if (recentJobs.Count == 0)
        {
            <div class="empty-state">
                <h4>No jobs available</h4>
                <p>Check back soon for new opportunities.</p>
            </div>
        }
        else
        {
            <div class="recent-jobs-grid">
                @foreach (var job in recentJobs)
                {
                    <div class="recent-job-card">
                        <div class="recent-job-top">
                            <div>
                                <h4>@job.Position</h4>
                                <p>@job.Company</p>
                            </div>
                            <span class="job-type-pill">@job.JobType</span>
                        </div>

                        <div class="recent-job-meta">
                            <span>@job.Location</span>
                            <span>@job.Category</span>
                        </div>

                        <div class="recent-job-footer">
                            <span class="@GetDeadlineBadgeClass(job.Deadline)">
                                @GetDeadlineText(job.Deadline)
                            </span>

                            <button class="icon-btn view-btn" @onclick="() => ViewJob(job.Id)">
                                View Details
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
</div>

@code {
    private List<JobApplicationModel>? jobs;
    private List<JobApplicationModel> recentJobs = new();
    private string errorMessage = "";

    private int totalJobs;
    private int totalCompanies;
    private int internshipCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobs();
    }

    private async Task LoadJobs()
    {
        try
        {
            jobs = await Http.GetFromJsonAsync<List<JobApplicationModel>>("api/Jobs") ?? new();

            totalJobs = jobs.Count;

            totalCompanies = jobs
                .Where(j => !string.IsNullOrWhiteSpace(j.Company))
                .Select(j => j.Company.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Count();

            internshipCount = jobs.Count(j =>
                !string.IsNullOrWhiteSpace(j.JobType) &&
                j.JobType.Equals("Internship", StringComparison.OrdinalIgnoreCase));

            recentJobs = jobs
                .OrderByDescending(j => j.PostedDate)
                .Take(6)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void GoToJobs()
    {
        Navigation.NavigateTo("/jobs");
    }

    private void ViewJob(int id)
    {
        Navigation.NavigateTo($"/jobs/details/{id}");
    }

    private string GetDeadlineText(DateTime deadline)
    {
        var daysLeft = (deadline.Date - DateTime.Today).Days;

        if (daysLeft < 0)
            return "Expired";

        if (daysLeft == 0)
            return "Ends Today";

        if (daysLeft == 1)
            return "1 Day Left";

        if (daysLeft <= 7)
            return $"{daysLeft} Days Left";

        return "Open";
    }

    private string GetDeadlineBadgeClass(DateTime deadline)
    {
        var daysLeft = (deadline.Date - DateTime.Today).Days;

        if (daysLeft < 0)
            return "deadline-badge expired";

        if (daysLeft <= 1)
            return "deadline-badge urgent";

        if (daysLeft <= 7)
            return "deadline-badge warning";

        return "deadline-badge safe";
    }
}